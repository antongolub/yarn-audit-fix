{
  "name": "@cypress/puppeteer",
  "version": "0.0.0-development",
  "description": "Plugin for enhancing Cypress tests with Puppeteer",
  "private": false,
  "main": "dist/plugin/index.js",
  "scripts": {
    "build": "rimraf dist && tsc || echo 'built, with errors'",
    "build-prod": "yarn build",
    "check-ts": "tsc --noEmit",
    "cypress:open": "node ../../scripts/cypress.js open",
    "cypress:run": "node ../../scripts/cypress.js run --browser chrome",
    "lint": "eslint",
    "semantic-release": "semantic-release",
    "test-debug": "vitest --inspect-brk --no-file-parallelism --test-timeout=0 --hook-timeout=0",
    "test": "vitest run",
    "test-watch": "vitest --watch",
    "watch": "rimraf dist && tsc --watch"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "puppeteer-core": "^21.2.1"
  },
  "devDependencies": {
    "@packages/eslint-config": "0.0.0-development",
    "@types/node": "^22.18.7",
    "eslint": "^9.31.0",
    "express": "4.21.0",
    "rimraf": "^6.1.1",
    "semantic-release": "22.0.12",
    "typescript": "5.4.5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "cypress": ">=13.6.0"
  },
  "files": [
    "dist",
    "support"
  ],
  "types": "dist/plugin/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cypress-io/cypress.git"
  },
  "homepage": "https://github.com/cypress-io/cypress/blob/develop/npm/puppeteer/#readme",
  "bugs": "https://github.com/cypress-io/cypress/issues/new?assignees=&labels=npm%3A%20%40cypress%2Fpuppeteer&template=1-bug-report.md&title=",
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json}": "eslint --fix"
  },
  "publishConfig": {
    "access": "public"
  },
  "nx": {}
}
