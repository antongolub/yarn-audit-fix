{
  "name": "@packages/launcher",
  "version": "0.0.0-development",
  "private": true,
  "scripts": {
    "build-prod": "tsc --project .",
    "check-ts": "tsc --noEmit && yarn -s tslint",
    "clean": "rimraf --glob 'lib/*.js' && rimraf --glob 'lib/**/*.js' || true",
    "clean-deps": "rimraf node_modules",
    "clean-js": "yarn clean",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx,.json, .",
    "size": "t=\"cypress-v0.0.0.tgz\"; yarn pack --filename \"${t}\"; wc -c \"cli/${t}\"; tar tvf \"${t}\"; rm \"${t}\";",
    "test": "yarn test-unit",
    "test-debug": "vitest --inspect-brk --no-file-parallelism --test-timeout=0",
    "test-unit": "vitest run",
    "tslint": "tslint --config ../ts/tslint.json --project ."
  },
  "dependencies": {
    "bluebird": "3.5.3",
    "debug": "^4.3.4",
    "execa": "4.1.0",
    "fs-extra": "9.1.0",
    "lodash": "^4.17.21",
    "plist": "3.1.0",
    "which": "2.0.2",
    "win-version-info": "^6.0.1"
  },
  "devDependencies": {
    "@packages/data-context": "0.0.0-development",
    "@packages/ts": "0.0.0-development",
    "@packages/types": "0.0.0-development",
    "mock-fs": "5.4.0",
    "typescript": "~5.4.5",
    "vitest": "^3.2.4"
  },
  "files": [
    "index.js",
    "lib"
  ],
  "types": "index.ts",
  "license": "MIT",
  "nx": {
    "implicitDependencies": [
      "@packages/data-context"
    ]
  }
}
