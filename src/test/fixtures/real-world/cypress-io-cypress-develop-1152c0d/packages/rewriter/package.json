{
  "name": "@packages/rewriter",
  "version": "0.0.0-development",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build-prod": "tsc --project .",
    "build-test": "yarn build-prod --noEmit",
    "check-ts": "tsc --noEmit && yarn -s tslint",
    "clean": "rimraf --glob 'lib/**/*.js'",
    "clean-deps": "rimraf node_modules",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx,.json, .",
    "test": "vitest run",
    "test-debug": "vitest --inspect-brk --no-file-parallelism --test-timeout=0",
    "tslint": "tslint --config ../ts/tslint.json --project ."
  },
  "dependencies": {
    "ast-types": "^0.16.1",
    "bluebird": "3.7.2",
    "debug": "^4.3.4",
    "lodash": "^4.17.19",
    "parse5-html-rewriting-stream": "5.1.1",
    "recast": "0.23.11"
  },
  "devDependencies": {
    "@cypress/request-promise": "^5.0.0",
    "@types/parse5-html-rewriting-stream": "5.1.2",
    "fs-extra": "9.1.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "lib"
  ],
  "types": "./lib/index.ts",
  "license": "MIT",
  "workspaces": {
    "nohoist": [
      "parse5-html-rewriting-stream",
      "parse5-html-rewriting-stream/**",
      "@types/parse5-html-rewriting-stream",
      "@types/parse5-html-rewriting-stream/**"
    ]
  },
  "nx": {}
}
